<Window
    x:Class="G.Sync.ConfigurationApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Obsidian Sync Configuration Panel">

    <Grid x:Name="RootGrid" Background="#1E1E1E">

        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="20" Spacing="12">

                <TextBlock Text="IP Address" Foreground="White"/>
                <TextBox Text="{Binding IpAddress, Mode=TwoWay}" PlaceholderText="127.0.0.1"
                         Background="#2D2D2D" Foreground="White" BorderBrush="#444444"/>

                <TextBlock Text="Port" Foreground="White"/>
                <TextBox Text="{Binding Port, Mode=TwoWay}" PlaceholderText="8080"
                         Background="#2D2D2D" Foreground="White" BorderBrush="#444444"/>

                <TextBlock Text="Google Drive Project Name" Foreground="White"/>
                <TextBox Text="{Binding GoogleDriveProjectName, Mode=TwoWay}" PlaceholderText="MyProject"
                         Background="#2D2D2D" Foreground="White" BorderBrush="#444444"/>

                <TextBlock Text="Local Folder" Foreground="White"/>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBox Width="300" Text="{Binding LocalFolderPath, Mode=TwoWay}" IsReadOnly="True"
                             Background="#2D2D2D" Foreground="White" BorderBrush="#444444"/>
                    <Button Content="Browse" Command="{Binding BrowseFolderCommand}"
                            Background="#3C3C3C" Foreground="White" BorderBrush="#555555"/>
                </StackPanel>

                <Button Content="Save" Width="100" HorizontalAlignment="Left" Margin="0,20,0,0"
                        Command="{Binding SaveConfig}" Background="#7C4DFF" Foreground="White" BorderBrush="#555555"/>
            </StackPanel>
        </ScrollViewer>

        <Grid x:Name="LoadingOverlay" Background="#80000000"
              Visibility="{Binding IsInstalling, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <ProgressRing IsActive="True" Width="60" Height="60"/>
                <TextBlock Text="Installing..." Foreground="White" FontSize="16" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>